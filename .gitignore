.Rhistory
.RData
.Rprofile
.Rproj.user/
renv/
renv.lock

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
*.swp
*~
*.bak
.vscode/
.idea/

# Large files
*.gmt
*.gmt.RDS

# Logs
*.log
